# Terminus runtime environment -- variable NAMES only, never values. Every
# credential here is materialized into the process environment at deploy
# time by the runtime secret store (<secret-manager>-backed vault); this file is
# documentation of what a full deployment expects to see set, not a place to
# author real values (see moosenet-spec S7).

# ── Documentation Engine (S95 DOCGEN) ───────────────────────────────────────
# Doc-target credentials. A project only needs the keys matching the doc
# targets it actually declares in its per-project doc-target config
# (`src/tools/docgen/config.rs`) -- an unconfigured project defaults to
# README-only and needs none of these. A declared target whose credential is
# absent is disabled with a hint at generation time; other declared targets
# still render (see DOCGEN-01's config `resolve()` and DOCGEN-06's render
# item).

# OpenRouter frontier-free tier -- used by Chord's SLM router (DOCGEN-03,
# later item) when a doc-generation request routes to cloud inference. Not
# read by the DOCGEN-01 scaffold itself.
OPENROUTER_API_KEY=

# Dedicated OpenRouter key for the review daemon's paid pool (+ gpt56) so
# review-provider spend is isolated/trackable; preferred over OPENROUTER_API_KEY
# by the review daemon (S121 REVX-09).
OPENROUTER_API_KEY_CHORDHARMONY=

# Notion integration token -- required only if a project declares a
# `notion` doc target.
NOTION_TOKEN=

# Obsidian-compatible vault sync token. NOT a render-time gate (DGFIX-02,
# TERM-200): rendering an `obsidian` doc target is pure and needs no
# credential -- this engine never places/pushes a note into a vault, only a
# future placement/push layer outside the doc engine would need this value.
# (Distinct from Scribe's own SCRIBE_VAULT_REMOTE/SCRIBE_VAULT_LOCAL_DIR,
# which are Scribe's own knowledge-vault write surface, not the doc
# engine's.)
OBSIDIAN_VAULT_TOKEN=

# Blog-target publish credential -- required only if a project declares a
# `blog` doc target.
DOCGEN_BLOG_API_TOKEN=

# Atlas knowledge-graph store (KGRAPH-03): root directory where per-project
# knowledge graphs are written, one `<project_slug>.json` per project. Not a
# secret -- a filesystem path. Defaults to `<tmpdir>/scribe-knowledge-graphs`.
SCRIBE_KG_STORE_DIR=

# Atlas semantic-edge pass (KGRAPH-04): opt-in. When "true"/"1"/"yes" AND the
# review daemon is configured, scribe_kg_build asks a model to propose
# INFERRED/AMBIGUOUS relationships a parser can't see. Off by default; a model
# failure is best-effort and keeps the deterministic (EXTRACTED) graph. Not a
# secret — a behavioral flag.
SCRIBE_KG_SEMANTIC=

# ── MINT coder sweep — measurement factors (S112 MINT2-01) ───────────────────
# Optional knobs recorded verbatim on every 'v3' code_profile_runs case row so
# pass-rate can be analyzed against the tunable that was set, not just the model
# name. All are OPT-IN: unset ⇒ the factor is recorded as "unset"/NULL (or
# "unknown" for quant), never guessed. No secrets — these are experiment config,
# names only per S7. See intake::code_v2::MeasurementFactors::from_env.
#
# Explicit quantization tag (e.g. Q4_K_M / Q6_K / fp16). When unset, the sweep
# parses a quant tag out of the model id; if the id declares none it records
# "unknown" (never a guess).
SWEEP_QUANT=
# Three-state reasoning/thinking flag the runtime was launched with:
# 1/true/on/yes ⇒ on, 0/false/off/no ⇒ off, unset ⇒ recorded as NULL (unset).
SWEEP_REASONING_ENABLED=
# The context window (-c / num_ctx) the runtime was launched with — a positive
# integer, distinct from the per-prompt observed context_tokens.
SWEEP_CONTEXT_WINDOW=
# Sampling temperature / top-p the run was configured with (finite floats).
# Unset ⇒ the runtime default was used and no specific value is recorded.
SWEEP_TEMPERATURE=
SWEEP_TOP_P=

# ── Media domain (S94/MEDIA-01) ─────────────────────────────────────────────
# Sovereign orchestration of the self-hosted media stack -- names only, no
# values, materialized at runtime via the secret store (see
# secrets_bootstrap::GITEA_PLANE_GITHUB_SECRET_KEYS). A service missing its
# pair below degrades gracefully: its client returns NotConfigured, other
# configured services are unaffected, and the domain still loads.

# Radarr (movies) -- base URL + X-Api-Key credential.
RADARR_URL=
RADARR_API_KEY=
# MEDIA-03: non-secret behavioral config for media_request's Radarr adds --
# which quality profile (integer id) and library root folder path to use.
RADARR_QUALITY_PROFILE_ID=
RADARR_ROOT_FOLDER_PATH=

# Sonarr (TV) -- base URL + X-Api-Key credential.
SONARR_URL=
SONARR_API_KEY=
# MEDIA-03: same idea as the Radarr pair above, for Sonarr adds.
SONARR_QUALITY_PROFILE_ID=
SONARR_ROOT_FOLDER_PATH=

# Prowlarr (indexer aggregation) -- base URL + X-Api-Key credential.
PROWLARR_URL=
PROWLARR_API_KEY=

# qtor (download client) -- base URL + Authorization credential.
QTOR_URL=
QTOR_CREDS=

# Plex (library/consumption/history) -- base URL + X-Plex-Token credential.
PLEX_URL=
PLEX_TOKEN=

# <media-service> (request-tracking + discovery) -- shared with the pre-existing
# crate::<media-service> read-only tool module; both consume the same pair.
JELLYSEERR_URL=
JELLYSEERR_API_KEY=

# TMDb (title resolution) -- the one external call in this domain. API key
# only; TMDB_API_URL is an optional, non-secret base-URL override (defaults
# to https://api.themoviedb.org/3) for tests/self-hosted proxies.
TMDB_API_KEY=
TMDB_API_URL=

# Taste-memory personalization (MEDIA-06) -- OPTIONAL, default OFF. Hard on/off
# toggle: the media domain works fully STATELESS without it (MEDIA-05 path). When
# on, media_recommend is replaced by a taste-aware decorator and a media_taste_feedback
# write-back tool is registered. Flag is three-state (1/true/on/yes = on; anything
# else, incl. unset, = off). MEDIA_TASTE_API_URL points at an assumed REST facade for
# the taste/curation store (non-secret base URL; wire shape not verified against a live
# service). If the flag is on but the URL is unset/unreachable, recommendations degrade
# to the stateless path -- personalization is never a hard dependency.
MEDIA_TASTE_MEMORY_ENABLED=
MEDIA_TASTE_API_URL=
# ── Upstream mesh registry (MESH-01) ─────────────────────────────────────────
# Config-driven federation targets, generalizing the single hard-coded upstream
# into a validated registry of many. Both are NON-SECRET structural config,
# read via plain env (never the runtime secret store): a feature flag and a
# JSON array. No credential value is ever authored here — each upstream entry
# references its credential by NAME only (`secret_key`), resolved lazily at
# dial time from the same env-materialized secret store convention every other
# secret in this crate uses.
#
# Master switch. Truthy = 1/true/yes/on (case-insensitive); anything else,
# including unset, leaves the mesh feature dormant (empty registry, never an
# error).
TERMINUS_MESH_ENABLED=
# JSON array of upstream Terminus MCP servers to federate. Each entry:
#   {
#     "name":       stable unique id (e.g. "personal"),
#     "url":        reachable base URL (non-empty),
#     "transport":  "mtls" | "bearer" (case-insensitive),
#     "namespace":  unique prefix, ^[a-z0-9]{2,16}$,
#     "secret_key": NAME of the credential in the runtime secret store
#                   (bearer transports); OMIT for pure-mTLS upstreams —
#                   NEVER an inline token value,
#     "enabled":    bool, default true (false = parsed but not dialed)
#   }
# Loaded/validated at startup; a malformed value while MESH is enabled is a
# clear startup error naming the offending field, not a silent empty registry.
TERMINUS_MESH_UPSTREAMS_JSON=

# ── MESH-04: embedded tailnet listener ──────────────────────────────────────
# Only meaningful when `terminus_primary` is compiled with the `tsnet` Cargo
# feature (off by default -- see Cargo.toml). Two independent gates, both
# must be on for the tailnet listener to actually start: this runtime flag,
# AND the compile-time feature. See src/mesh/tailnet.rs's module doc for the
# full design (binding choice, WhoIs scope boundary).
#
# Runtime master switch for the tsnet listener. Truthy = 1/true/yes/on
# (case-insensitive); anything else, including unset, leaves it off -- the
# plain + mTLS listeners are unaffected either way.
TERMINUS_MESH_TAILNET_ENABLED=

# MagicDNS hostname this node advertises on the tailnet. Required when the
# flag above is on; no auto-generated default (an operator-chosen, stable
# hostname is the point of MagicDNS here).
TERMINUS_TSNET_HOSTNAME=

# Local directory tsnet persists its node state/keys under. Required when the
# flag above is on; created (and write-probed) at startup if missing.
TERMINUS_TSNET_STATE_DIR=

# Tailnet auth key. Like every other credential in this file, this is a
# variable NAME only -- the runtime secret store (<secret-manager>-backed vault)
# materializes the real value into the process environment at deploy time;
# never author a literal key here. Read once at startup and immediately
# wrapped in the redacted `ResolvedSecret` type -- never logged.
TERMINUS_TSNET_AUTHKEY=

# ── MESH-06: unified Principal identity mapping ─────────────────────────────
# Config-driven mapping from an inbound TRANSPORT identity (mTLS client cert
# CN, and/or tailnet WhoIs login/tag) to a single canonical `name` -- the same
# string space `PLANE_PAT_<NAME>` / `GITEA_PAT_<NAME>` / `GITHUB_PAT_<NAME>`
# already use. That canonical name drives BOTH the gateway allowlist/RBAC
# decision (`crate::gateway_framework`) and downstream named-PAT selection.
# NON-SECRET structural config (identity strings, not credential values) --
# read via plain env, same as `TERMINUS_MESH_UPSTREAMS_JSON` above.
#
# Precedence when resolved via `crate::mesh::PrincipalResolver::resolve`
# (see that module's doc for full detail): a present mTLS cert CN is checked
# FIRST and EXCLUSIVELY -- if mapped, it wins outright, even when a tailnet
# identity is also present; if NOT mapped, resolution fails closed (denied)
# rather than falling back to the tailnet identity. Tailnet login/tag is only
# consulted when NO cert is presented. Neither present, or the one presented
# has no mapping entry, => denied. Unlike `TERMINUS_GATEWAY_ALLOWLIST_JSON`,
# malformed JSON here is a HARD startup error, not a silent degrade -- see
# `crate::mesh::principal`'s module doc for why.
#
# JSON object, all three keys optional (absent = empty map for that lookup):
#   {
#     "cert_cn":       { "<mTLS cert Subject CN>": "<canonical name>" },
#     "tailnet_login":  { "<tailnet login>": "<canonical name>" },
#     "tailnet_tag":    { "<tailnet ACL tag, e.g. \"tag:ci\">": "<canonical name>" }
#   }
# Example:
#   {"cert_cn": {"harmony-primary.example.test": "harmony"}, "tailnet_login": {"<email>": "moose"}}
TERMINUS_MESH_PRINCIPAL_MAP_JSON=

# ── TGW-04 / LHEG-07 / MESH-08: gateway per-identity allowlist (RBAC) ───────
# JSON object: `<canonical Principal name> -> <grant>`, where a grant is
# EITHER a plain array (`["tool_a", "tool_b", "*"]`, exact-match plus
# optional bare `"*"` wildcard) OR an allow/deny object
# (`{"allow": [...], "deny": [...]}`, LHEG-07) where `deny` PREFIXES win even
# over an `allow: ["*"]` wildcard. `lumina`/`harmony` are always recognized
# even when absent from this JSON (see `crate::gateway_framework`'s
# `SCAFFOLDED_IDENTITIES` doc); every other identity absent from this map is
# denied every action (default-deny). Malformed JSON degrades to a
# scaffold-only (deny-all except lumina/harmony) policy, logged loudly --
# unlike TERMINUS_MESH_PRINCIPAL_MAP_JSON above, this one must never panic
# the gateway process over a config typo.
#
# MESH-08 (per-upstream, per-tool RBAC over MESH-01/03's namespaced mesh
# tools, `<namespace>__<tool>`): an `allow`/plain-list entry may be:
#   "*"                    -- every tool/route (plain or namespaced)
#   "ct322__*"             -- every tool exported by the mesh upstream
#                              registered under namespace "ct322" (a
#                              namespace-wide wildcard: any entry ending in
#                              "*" matches every action starting with the
#                              text before that "*")
#   "ct322__ledger_add"    -- exactly that one namespaced tool
#   "ledger_add"           -- a plain local tool name (pre-mesh behavior,
#                              unchanged)
# A `deny` PREFIX is checked against the action as given AND, for a
# namespaced action, against its bare (post-`__`) tool name too -- so
# `DEFAULT_SENSITIVE_DENY_PREFIXES` entries like "github_" keep closing off
# a sensitive tool re-exported through ANY mesh upstream namespace, not just
# the local/bare form (e.g. "ct322__github_push_repo" is denied by the
# "github_" deny entry exactly like "github_push_repo" is).
# `tools/list` visibility and `tools/call` enforcement both consult this
# SAME policy for the SAME (possibly namespaced) tool name -- a tool never
# advertised to a caller it could not also call, and vice versa.
#
# Example: grant `ct322-viewer` every ct322 tool except its sensitive
# `vitals_*` ones, and nothing else at all:
#   {"ct322-viewer": {"allow": ["ct322__*"], "deny": ["ct322__vitals_"]}}
TERMINUS_GATEWAY_ALLOWLIST_JSON=

# ── git-public full-history backfill (GHIST) ──────────────────────────────────
# Path to a TOML file mapping internal git author identities to the PUBLIC
# identities used when replaying history to the public mirror (GHIST-03). Keeps
# every real email OUT of source — the addresses live only in this deployment
# file. Unset = no remap (authors passed through unchanged; NOT for public use).
# Format:
#   default_name  = "moosenet-bot"
#   default_email = "<numeric-id>+<bot-user>@users.noreply.github.com"
#   [[rules]]
#   match_email   = "<email>"       # exact (case-insensitive), OR
#   match_email_domain = "example.internal"    #   @example.internal suffix, OR
#   match_name    = "Some Name"                #   exact display name
#   public_name   = "PublicName"
#   public_email  = "<numeric-id>+<user>@users.noreply.github.com"
# First matching rule wins; unmatched idents fall through to default_* (never the
# raw internal email). Timestamps are always preserved (contribution-date fidelity).
# TERMINUS_MIRROR_AUTHOR_MAP=/opt/terminus-primary/mirror-author-map.toml
#
# GHIST-08 going-forward sync (git_public_history_sync) reuses the same
# TERMINUS_MIRROR_AUTHOR_MAP (fail-closed), TERMINUS_MIRROR_WORKDIR_ROOT (history
# work-dirs), TERMINUS_MIRROR_SOURCE_ROOT (internal-main checkouts), and
# TERMINUS_MIRROR_REMOTE[_<REPO>] (public remotes) as the backfill/push tools. It
# appends new commits onto the operator-blessed baseline, gates ONLY the new
# commits, and fast-forward-pushes clean results (never force). Drive it on a
# cadence with deploy/terminus-mirror-history-sync.{service,timer}.

# ── Cortex — Atlas-backed code-intelligence gate (CXEG-01) ──────────────────
# CXEG-01 retired Cortex's SSH-relay-era transport to the (now-retired) fleet
# host entirely -- there is no CORTEX_SSH_HOST / CORTEX_SSH_USER /
# CORTEX_SSH_KEY_PATH / CORTEX_SCRIPT config surface any more. The vars below
# are non-secret tuning flags for `cortex_scope`/`cortex_review`/`cortex_audit`
# (currently pending-rebuild stubs -- see docs/tools/code-git/cortex.md),
# read directly via std::env::var since none of them are secret-shaped.
# Risk score (0-10 scale) at/above which cortex_review should flag escalation
# once its Atlas-backed rebuild (CXEG-04) lands. Default 7.0.
CORTEX_RISK_SCORE_THRESHOLD=
# Feature flags for not-yet-built analysis tiers. Default false for both.
CORTEX_ENABLE_TIER_B=
CORTEX_ENABLE_TIER_C=
# Whether elegance/style findings are advisory-only (never blocking). Default true.
CORTEX_ELEGANCE_ADVISORY_ONLY=
# Cosine-similarity threshold for a not-yet-built dup-detection pass. Default 0.85.
CORTEX_DUP_COSINE_THRESHOLD=
#
# The Atlas KG's own Postgres DSN (ATLAS_DATABASE_URL) is a separate,
# secret-shaped value read exclusively through crate::config::atlas_database_url()
# -- see KGRAPH-03 / the Atlas knowledge-graph store entry above for the
# non-Postgres (filesystem) graph store path; the pgvector-backed store is
# documented alongside crate::scribe::graph::vec_embed's own module doc.

# ── CONST-02: constellation aggregation API layer ───────────────────────────
# Compiled-in module (crate::constellation, merged into build_router — NOT a
# broker worker, see docs/architecture/broker.md) serving `/api/*`, `/ws`, and
# the built constellation-web SPA (CONST-15: embedded into the binary via
# rust-embed by default — see CONSTELLATION_WEB_DIST_DIR below).
# Base URLs the four namespaced proxy routes (/api/{harmony,chord,lumina,muse}/*)
# forward to. Unset -> that system reports available:false rather than a
# guessed host (see crate::constellation::proxy's module doc).
CONSTELLATION_HARMONY_URL=
CONSTELLATION_CHORD_URL=
CONSTELLATION_LUMINA_URL=
# CONST-19: Muse's base URL. /api/muse/art/* additionally passes through
# binary art/poster responses with the upstream content-type, skipping JSON
# masking (see crate::constellation::proxy's module doc).
CONSTELLATION_MUSE_URL=
# LGUI-05 (LUMINA-GUI-SPEC.md §6, decision D2): bearer credential
# crate::constellation::proxy::proxy_lumina attaches as `Authorization: Bearer
# <token>` on every proxied /api/lumina/*path request -- the browser never
# holds (and can never supply) a Lumina credential; only the operator's
# Constellation session cookie authenticates the browser, this is what
# separately authenticates Terminus to Lumina. Operator-provisioned in
# <secret-manager> -- NEVER hardcode a value here. Same value as Lumina's own
# LUMINA_HTTP_TOKEN (two consumers, one secret). Unset -> proxy_lumina
# forwards unauthenticated exactly as before this item (a token-less dev
# Lumina instance keeps working), never a hard failure. Secret-shaped, so
# read directly via env_nonempty at the point of use
# (crate::config::constellation_lumina_token), not through a
# SecretManager/vault::manager() call -- this crate has none (see
# crate::pki's module doc).
CONSTELLATION_LUMINA_TOKEN=
# CONST-18: upstream WS URL the /ws relay dials for Harmony's own event
# stream (engine/ralph-loop/log events), once a browser's upgrade has been
# session-cookie-verified. Unset -> the relay accepts the upgrade then
# immediately sends a typed close frame; the UI stays on 30s polling.
CONSTELLATION_HARMONY_WS_URL=
# OPTIONAL DEV OVERRIDE ONLY (CONST-15). Production serves the constellation-web
# UI from the assets EMBEDDED in the binary at cargo-build time (rust-embed over
# the committed constellation-web/dist/ — see constellation-web/README.md
# "Embedded build (CONST-15)"); no npm/node toolchain is needed at build time.
# Set this to a filesystem directory (a built constellation-web dist/ output) to
# serve from disk instead — e.g. against a live-reloading local build. Unset ->
# serve the embedded assets.
CONSTELLATION_WEB_DIST_DIR=
# Per-request timeout (ms) for a proxied /api/{system}/* backend call.
# Default 5000.
CONSTELLATION_BACKEND_TIMEOUT_MS=
# Filesystem path the S6-sanitized mutating-request (POST/PUT/PATCH/DELETE)
# audit JSONL is appended to. Default constellation-audit.jsonl (relative to
# the process's working directory).
CONSTELLATION_AUDIT_LOG_PATH=
# CONST-26: max entries GET /api/terminus/activity tail-reads from the audit
# JSONL above and returns (a caller's own ?limit= may ask for fewer, never
# more). Default 200.
CONSTELLATION_ACTIVITY_TAIL_LIMIT=

# ── CONST-03: constellation control-plane auth ───────────────────────────────
# Real signed-session auth for the CONST-02 aggregation layer above --
# crate::constellation::auth verifies login against a shared operator secret
# and mints a TERMINUS_JWT_SIGNING_KEY-signed session JWT (the SAME signing
# key TCLI-02's /enroll endpoint uses -- see the "TCLI-02" section of this
# file if present, or docs/architecture/auth.md). An unset
# CONSTELLATION_OPERATOR_SECRET means every login attempt fails closed (never
# a default-allow). Both of the following are secret-shaped and read directly
# via std::env::var/env_nonempty at the point of use, NOT through a
# crate::config helper (see crate::pki's module doc for why this crate has no
# separate SecretManager/vault::manager() API):
#   TERMINUS_JWT_SIGNING_KEY        -- HS256 session-signing key (shared with
#                                       TCLI-02 enrollment JWTs)
#   CONSTELLATION_OPERATOR_SECRET   -- the login credential, compared in
#                                       constant time
# Session token TTL, in seconds. Default 3600 (1 hour). Independent of
# TERMINUS_ENROLLMENT_JWT_TTL_SECONDS (a different credential/lifecycle).
CONSTELLATION_SESSION_TTL_SECONDS=
# Whether the session cookie carries the Secure attribute (HTTPS-only).
# Default false (a LAN-served dev/operator UI may run over plain HTTP) --
# set true when this is served behind TLS.
CONSTELLATION_COOKIE_SECURE=

# ── CONST-27: viewer role ─────────────────────────────────────────────────────
# Adds a read-only "viewer" tier on top of CONST-03's auth above -- the SAME
# session JWT gains a `role` claim rather than a new auth system. Login checks
# CONSTELLATION_OPERATOR_SECRET first (role=operator), then this secret
# (role=viewer), both constant-time. A viewer session gets a structural 403
# on every mutating method (POST/PUT/PATCH/DELETE) under
# /api/{harmony,chord,lumina,muse}/* -- enforced server-side
# (crate::constellation::auth::enforce_viewer_role_gate), never just in the
# UI.
#
# Operator-provisioned in <secret-manager> at deploy time -- NEVER hardcode a value
# here or anywhere else. Secret-shaped, so read the same way
# CONSTELLATION_OPERATOR_SECRET is (std::env::var/env_nonempty at the point
# of use, via crate::config::constellation_viewer_secret(), not a
# SecretManager/vault::manager() call -- this crate has none, see crate::pki's
# module doc).
#
# Unset (the default) DISABLES the viewer tier entirely -- fail-closed, same
# posture as an unset CONSTELLATION_OPERATOR_SECRET: no password can ever
# match a secret that isn't configured, never a default-allow. Set this to a
# value DISTINCT from CONSTELLATION_OPERATOR_SECRET -- if the two are equal,
# the operator check (which runs first) always wins on a match, so the
# viewer tier becomes unreachable (logged as a warning, never blocks login).
CONSTELLATION_VIEWER_SECRET=

# ── GMQ-02: Gitea merge queue (per-base merge lock + FIFO ordering) ─────────
# crate::gitea::merge_queue::MergeQueue serializes gitea_merge_pr merges to
# the same base branch so concurrent build agents never race a stale-based
# merge (docs/specs/S120-gitea-merge-queue.md). Reuses the shared REDIS_URL
# backend (see the top of this file) -- no separate endpoint. DEGRADES OPEN:
# with Redis absent/unreachable, merges behave exactly as before (unqueued).
# All three are optional with safe defaults.
#
# Whether the merge-queue path is enabled ("true"/"1" -> true). Default true
# (once Redis is present, protect concurrent merges by default).
GITEA_MERGE_QUEUE_ENABLED=
# Merge-lock TTL in seconds -- the crash backstop that frees a holder's lock
# if it never releases. Must exceed a realistic merge time. Default 120.
GITEA_MERGE_QUEUE_LOCK_TTL_SECS=
# Max seconds a waiter polls for its turn before giving up with a clear
# "queue busy, retry" instead of hanging indefinitely. Default 300.
GITEA_MERGE_QUEUE_MAX_WAIT_SECS=
# TTL in seconds for the wait ZSET's own self-healing EXPIRE backstop (bounds
# how long an abandoned waiter, e.g. a crashed caller, can wedge a key).
# Default is derived from GITEA_MERGE_QUEUE_MAX_WAIT_SECS (+60s) so it can
# never be shorter than the longest a real waiter can legitimately poll. If
# set explicitly BELOW GITEA_MERGE_QUEUE_MAX_WAIT_SECS + 60s, the effective
# value is CLAMPED UP to that floor rather than honored literally -- a
# shorter wait TTL would expire the wait ordering out from under a
# still-legitimately-polling waiter.
GITEA_MERGE_QUEUE_WAIT_TTL_SECS=
# ── GMQ-03: min-delay spacing + stale-base guard ────────────────────────────
# Minimum seconds required between two merges to the SAME base key -- lets
# `main` settle / mirror+CI react before the next merge lands. 0 disables
# spacing entirely (no artificial delay). Default 8. The wait (if any) is
# bounded by GITEA_MERGE_QUEUE_MAX_WAIT_SECS above -- a spacing wait that
# would exceed it returns MergeQueueError::Busy instead of sleeping past the
# ceiling.
GITEA_MERGE_QUEUE_MIN_DELAY_SECS=

# PCON-06: in-slot rebase + re-gate (Bors / GitHub-merge-queue model). When on,
# a stale-base (NotMergeable) PR is REBASED (the branch is replayed on top of
# current base via the sanctioned Gitea branch-update path — always style=rebase;
# a merge-commit update is rejected) and RE-GATED (a fresh compiler_build
# mode=test gate on the CONFIRMED post-rebase head — advanced past the pre-update
# head AND mergeable against current base) INSIDE the merge queue's
# critical section -- merging ONLY on a green gate, bound to the gated commit
# (head_commit_id) with a captured-base recheck immediately before the POST -- so
# each merge is tested against the base it lands on. A rebase conflict, a red
# re-gate, a gate timeout, a moved head, a base advance, or an expired lease each
# bounce to the author with a DISTINCT reason; they never merge. "true"/"1" => on,
# anything else => off. Default ON where the compiler build door is reachable.
# Turning it OFF (or the compiler door being unreachable at re-gate time, or Redis
# absent so there is no queue) falls back to the pre-PCON-06 behavior: bounce
# "rebase current base and retry" to the caller -- a fail-safe path that never
# blind-merges and never holds the slot.
# LEASE: the re-gate holds the merge slot for the whole rebase->gate->merge span,
# so GITEA_MERGE_QUEUE_LOCK_TTL_SECS must comfortably exceed a re-gate build's
# duration (the op is HARD-bounded to lock_ttl - 30s, re-checked immediately
# before the merge POST); a lease too short is REFUSED up front, and an op that
# overruns the deadline bounces rather than POSTing.
#
# SCOPE OF THE GUARANTEE (read this — it is NOT "always green" unconditionally):
# The exact-landing-state invariant holds for every QUEUE-MEDIATED change: no two
# queued merges to the same base race, and each merge is gated against and bound
# to the base/head it lands on. There is ONE irreducible residual: a DIRECT,
# out-of-queue push to `main` in the sub-second window between the pre-merge
# base-recheck and the merge POST can still advance the base — Gitea exposes NO
# server-side base guard (only head_commit_id for the head) to close that window
# atomically. The COMPLETE closure is an OPS step outside this code: configure
# `main` as a PROTECTED BRANCH so ONLY the merge queue's identity can push to it.
# With branch protection on, there are no out-of-queue pushes and the residual
# window cannot occur; without it, PCON-06 narrows and enforces the window (lease
# + recheck) but cannot claim absolute atomicity against a direct push.
BUILD_MERGE_REGATE_ENABLED=

# ── PCON-09: resource-aware build admission ─────────────────────────────────
# With per-SHA stage/target isolation (PCON-01..04) the per-(module,sha) lock no
# longer force-serializes different SHAs of one module -- it only guards the
# IDENTICAL sha. What still needs bounding is the host's finite RAM/disk, so many
# independent SHAs cannot OOM the box (Plex lives here too). This controller
# decides HOW MANY builds admit concurrently; the per-build systemd-scope cgroup
# caps (MemoryMax/MemorySwapMax=0/CPUQuota) are UNCHANGED and still bound each one.
# EVERY knob defaults to OFF (0), so unset == today's behavior (per-host cap +
# (module,sha) lock); an operator opts in. Degrade-open throughout.
#
# Total concurrent build RAM (MB) admissible on a host: a job is claimed only if
# the sum of the currently-building jobs' peaks plus its own peak fits here.
# 0 (default) => the RAM gate is DISABLED.
BUILD_CONCURRENCY_MAX_RAM_MB=
# Host concurrent-job cap (all modules). 0/unset => fall back to the per-role
# BUILD_HOST_CAP_PRIMARY / BUILD_HOST_CAP_HEAVY.
BUILD_CONCURRENCY_MAX_JOBS=
# Free-disk floor (MB) on the build-scratch filesystem (BUILD_CONCURRENCY_DISK_PATH)
# below which NO new build admits this tick (they stay queued, retry once space is
# reclaimed). 0 (default) => no disk gate. Degrades OPEN if the path is unreadable.
BUILD_CONCURRENCY_MIN_DISK_MB=
# The filesystem the disk floor is checked against (e.g. the big appdata build
# disk). Unset => the disk gate is skipped even if MIN_DISK_MB is set (we will not
# guess a path to stat).
BUILD_CONCURRENCY_DISK_PATH=
# Conservative per-module peak-build RAM (MB) used for a module that has no
# BUILD_MODULE_PEAK_MB_<MODULE> configured, so RAM admission never over-commits on
# an unknown module. Default 4096.
BUILD_MODULE_PEAK_MB_DEFAULT=

# ── PCON-10: per-job build scratch (CARGO_TARGET_DIR + TMPDIR) ───────────────
# The big-disk ROOT under which a LOCAL build gets a PER-JOB CARGO_TARGET_DIR and
# TMPDIR (`<root>/<unit>/target` + `<root>/<unit>/tmp`), so two concurrent local
# builds never share a target/temp dir and neither lands on the small /tmp tmpfs
# (which caused tmpfs+disk exhaustion). Both are validated exec-safe and OFF the
# NFS dataset, and the per-job dir is reclaimed on finalize (PCON-05 GC is the
# crash backstop). Prefer this; if unset, the local path falls back to
# BUILD_LOCAL_TARGET_DIR. If BOTH are unset the build FAILS CLOSED — it will not
# silently use /tmp tmpfs. (The heavy/remote path uses a per-job target under
# BUILD_HEAVY_LOCAL_TARGET_DIR with its TMPDIR nested inside it — PCON-03/10.)
BUILD_SCRATCH_ROOT=

# ── REVX-03..07,14: review_run dynamic effort policy ────────────────────────
# Non-secret tunables (thresholds, provider-role sets) for the per-provider
# reasoning-effort policy in src/review/effort_policy.rs. All optional --
# defaults are chosen so a neutral medium diff still maps to Medium (the
# pre-policy static behavior).

# REVX-16: routine-review wall-clock backstop (secs). High-reasoning review
# agents (codex/opus/agy at a raised effort tier) legitimately think for several
# minutes on a large diff; the old hard-coded 120s killed them mid-think and
# poisoned the panel to a spurious REQUEST_CHANGES. Default 300 (5 min). This
# value is the Medium ANCHOR, not the max dispatched budget: tiers scale off it
# (Minimal 0.6x .. Xhigh 2x, so High/Xhigh = 480/600 at the default). The anchor
# is clamped to [120, 900]; the 120s lower bound is the old hard-coded value (you
# never want LESS) and the 900s upper bound (= daemon_max/2) means the highest
# tier (Xhigh, 2x) reaches EXACTLY the daemon MAX_TIMEOUT_SECS of 1800 without
# collapsing High onto it -- so the tiers stay strictly monotonic at every valid
# anchor. The effective dispatched backstop therefore still spans up to 1800s (at
# Xhigh); operators wanting a longer WHOLE-review budget use Epic/explore mode.
# The daemon's stall detector, not this ceiling, is the primary bound for a
# wedged provider.
REVIEW_ROUTINE_TIMEOUT_SECS=

# REVX-16: HTTP client ceiling (secs) for the direct OpenRouter review arms
# (free/paid/gpt56/nemotron/qwen_coder). A high-reasoning paid model
# (kimi-k2-thinking, deepseek-v3.2 with reasoning) can take minutes; default 300
# (was a fixed 150s that cut it off).
REVIEW_OPENROUTER_TIMEOUT_SECS=

# Master switch. Unset/1/true = enabled (dynamic per-provider effort). Set to
# 0/false to restore the OLD static-medium behavior exactly (only REVCAP-01's
# fixed intensive-substitute floor still applies). IMPORTANT: disabling this
# only disables DYNAMIC tier/model SELECTION -- it does NOT revert REVX-08's
# codex model upgrade. With the policy disabled, codex still runs its fixed
# GPT-5.6 default (`gpt-5.6-sol`, `review_daemon/provider.rs::CODEX_MODEL`)
# at a fixed default reasoning effort; the REVIEW_CODEX_MODEL_SOL/_TERRA/_LUNA
# per-tier overrides below only take effect when the policy is ENABLED.
REVIEW_EFFORT_POLICY_ENABLED=

# The tier ("minimal"|"low"|"medium"|"high"|"xhigh") a diff with NO signals
# at all maps to. Default medium.
REVIEW_EFFORT_BASELINE_TIER=

# LOC-changed threshold (inclusive) that escalates the tier one step.
# Default 400.
REVIEW_EFFORT_LOC_ESCALATE=
# LOC-changed threshold (inclusive, and-below) treated as "small" in the run
# record's reasons (informational only). Default 20.
REVIEW_EFFORT_LOC_DEESCALATE=
# Files-touched threshold that escalates the tier one step. Default 8.
REVIEW_EFFORT_FILES_ESCALATE=
# Distinct top-level-directory (cross-module) threshold that escalates the
# tier one step. Default 3.
REVIEW_EFFORT_CROSS_MODULE_ESCALATE=

# REVX-04 prior-pass adaptive lever: the highest tier a contested re-review
# can ever reach via pass-history escalation alone. Default high.
REVIEW_EFFORT_MAX_ESCALATION_TIER=
# Once a re-review's pass_number exceeds this AND the change is still
# contested, the run is flagged hand_off:true (route to a human) instead of
# escalating further. Default 4.
REVIEW_EFFORT_MAX_PASSES_BEFORE_HANDOFF=

# REVX-05 role classification: comma-separated provider-name overrides.
# Empty/unset falls back to the built-in defaults
# (capstone: opus,codex,agy,claude-fable-5,paid;
#  breadth-tail: free,nemotron,qwen_coder,diffusion).
REVIEW_EFFORT_CAPSTONE_PROVIDERS=
REVIEW_EFFORT_BREADTH_TAIL_PROVIDERS=

# REVX-03 risk-path classification: comma-separated path substrings
# (case-insensitive) that classify a touched file as HIGH risk. Empty/unset
# falls back to the built-in security/secrets/auth/egress/unsafe/migration/
# concurrency/payment set.
REVIEW_EFFORT_RISK_PATHS=
# Path substrings that (absent any HIGH signal) classify a change as LOW
# risk. Empty/unset falls back to the built-in docs/comments/formatting/
# test-only set.
REVIEW_EFFORT_LOW_RISK_PATHS=

# REVX-13: the highest tier `claude-fable-5` will ever run at from the
# POLICY (an explicit caller override still wins) -- protects its very
# limited Max-subscriber token allocation. Default medium.
REVIEW_EFFORT_FABLE_MAX_TIER=

# REVX-07/08: per-tier codex model overrides -- GPT-5.6's three named
# variants. Lets an operator drop a tier under a rate limit without a
# redeploy. Defaults: high/xhigh -> gpt-5.6-sol, medium -> gpt-5.6-terra,
# minimal/low -> gpt-5.6-luna.
REVIEW_CODEX_MODEL_SOL=
REVIEW_CODEX_MODEL_TERRA=
REVIEW_CODEX_MODEL_LUNA=

# REVX-09/10/11: the `paid` pooled OpenRouter provider (curated,
# capstone-quality paid models -- Kimi K2/K2-thinking, DeepSeek V3.2,
# GLM-5/4.6, Gemini 2.5 Pro). The review daemon reads OPENROUTER_API_KEY_CHORDHARMONY
# FIRST (dedicated key isolating review-provider spend), falling back to the
# shared OPENROUTER_API_KEY when it is absent -- read at the dispatch boundary,
# never hardcoded.

# Comma-separated model-id override (chooses AMONG the closed set of known
# OpenRouter providers). Entries are VALIDATED: bad-shape / unknown-provider /
# `:free` entries are dropped; if none valid, the built-in curated 6 are used.
REVIEW_PAID_POOL_MODELS=
# Per-model cooldown (secs) after a 429 before it's retried. Default 600.
REVIEW_PAID_POOL_COOLDOWN_SECS=
# REVX-11 runtime toggle's process-lifetime DEFAULT (an agent can flip this
# at runtime via the review_paid_pool_toggle tool without touching this var;
# it only seeds the initial state on process start). Default false -- paid
# spend is operator-gated, never implicitly on.
REVIEW_PAID_POOL_ENABLED=
