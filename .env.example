# Terminus runtime environment -- variable NAMES only, never values. Every
# credential here is materialized into the process environment at deploy
# time by the runtime secret store (<secret-manager>-backed vault); this file is
# documentation of what a full deployment expects to see set, not a place to
# author real values (see moosenet-spec S7).

# ── Documentation Engine (S95 DOCGEN) ───────────────────────────────────────
# Doc-target credentials. A project only needs the keys matching the doc
# targets it actually declares in its per-project doc-target config
# (`src/tools/docgen/config.rs`) -- an unconfigured project defaults to
# README-only and needs none of these. A declared target whose credential is
# absent is disabled with a hint at generation time; other declared targets
# still render (see DOCGEN-01's config `resolve()` and DOCGEN-06's render
# item).

# OpenRouter frontier-free tier -- used by Chord's SLM router (DOCGEN-03,
# later item) when a doc-generation request routes to cloud inference. Not
# read by the DOCGEN-01 scaffold itself.
OPENROUTER_API_KEY=

# Notion integration token -- required only if a project declares a
# `notion` doc target.
NOTION_TOKEN=

# Obsidian-compatible vault sync token. NOT a render-time gate (DGFIX-02,
# TERM-200): rendering an `obsidian` doc target is pure and needs no
# credential -- this engine never places/pushes a note into a vault, only a
# future placement/push layer outside the doc engine would need this value.
# (Distinct from Scribe's own SCRIBE_VAULT_REMOTE/SCRIBE_VAULT_LOCAL_DIR,
# which are Scribe's own knowledge-vault write surface, not the doc
# engine's.)
OBSIDIAN_VAULT_TOKEN=

# Blog-target publish credential -- required only if a project declares a
# `blog` doc target.
DOCGEN_BLOG_API_TOKEN=

# Atlas knowledge-graph store (KGRAPH-03): root directory where per-project
# knowledge graphs are written, one `<project_slug>.json` per project. Not a
# secret -- a filesystem path. Defaults to `<tmpdir>/scribe-knowledge-graphs`.
SCRIBE_KG_STORE_DIR=

# Atlas semantic-edge pass (KGRAPH-04): opt-in. When "true"/"1"/"yes" AND the
# review daemon is configured, scribe_kg_build asks a model to propose
# INFERRED/AMBIGUOUS relationships a parser can't see. Off by default; a model
# failure is best-effort and keeps the deterministic (EXTRACTED) graph. Not a
# secret — a behavioral flag.
SCRIBE_KG_SEMANTIC=

# ── MINT coder sweep — measurement factors (S112 MINT2-01) ───────────────────
# Optional knobs recorded verbatim on every 'v3' code_profile_runs case row so
# pass-rate can be analyzed against the tunable that was set, not just the model
# name. All are OPT-IN: unset ⇒ the factor is recorded as "unset"/NULL (or
# "unknown" for quant), never guessed. No secrets — these are experiment config,
# names only per S7. See intake::code_v2::MeasurementFactors::from_env.
#
# Explicit quantization tag (e.g. Q4_K_M / Q6_K / fp16). When unset, the sweep
# parses a quant tag out of the model id; if the id declares none it records
# "unknown" (never a guess).
SWEEP_QUANT=
# Three-state reasoning/thinking flag the runtime was launched with:
# 1/true/on/yes ⇒ on, 0/false/off/no ⇒ off, unset ⇒ recorded as NULL (unset).
SWEEP_REASONING_ENABLED=
# The context window (-c / num_ctx) the runtime was launched with — a positive
# integer, distinct from the per-prompt observed context_tokens.
SWEEP_CONTEXT_WINDOW=
# Sampling temperature / top-p the run was configured with (finite floats).
# Unset ⇒ the runtime default was used and no specific value is recorded.
SWEEP_TEMPERATURE=
SWEEP_TOP_P=

# ── Media domain (S94/MEDIA-01) ─────────────────────────────────────────────
# Sovereign orchestration of the self-hosted media stack -- names only, no
# values, materialized at runtime via the secret store (see
# secrets_bootstrap::GITEA_PLANE_GITHUB_SECRET_KEYS). A service missing its
# pair below degrades gracefully: its client returns NotConfigured, other
# configured services are unaffected, and the domain still loads.

# Radarr (movies) -- base URL + X-Api-Key credential.
RADARR_URL=
RADARR_API_KEY=
# MEDIA-03: non-secret behavioral config for media_request's Radarr adds --
# which quality profile (integer id) and library root folder path to use.
RADARR_QUALITY_PROFILE_ID=
RADARR_ROOT_FOLDER_PATH=

# Sonarr (TV) -- base URL + X-Api-Key credential.
SONARR_URL=
SONARR_API_KEY=
# MEDIA-03: same idea as the Radarr pair above, for Sonarr adds.
SONARR_QUALITY_PROFILE_ID=
SONARR_ROOT_FOLDER_PATH=

# Prowlarr (indexer aggregation) -- base URL + X-Api-Key credential.
PROWLARR_URL=
PROWLARR_API_KEY=

# qtor (download client) -- base URL + Authorization credential.
QTOR_URL=
QTOR_CREDS=

# Plex (library/consumption/history) -- base URL + X-Plex-Token credential.
PLEX_URL=
PLEX_TOKEN=

# <media-service> (request-tracking + discovery) -- shared with the pre-existing
# crate::<media-service> read-only tool module; both consume the same pair.
JELLYSEERR_URL=
JELLYSEERR_API_KEY=

# TMDb (title resolution) -- the one external call in this domain. API key
# only; TMDB_API_URL is an optional, non-secret base-URL override (defaults
# to https://api.themoviedb.org/3) for tests/self-hosted proxies.
TMDB_API_KEY=
TMDB_API_URL=

# Taste-memory personalization (MEDIA-06) -- OPTIONAL, default OFF. Hard on/off
# toggle: the media domain works fully STATELESS without it (MEDIA-05 path). When
# on, media_recommend is replaced by a taste-aware decorator and a media_taste_feedback
# write-back tool is registered. Flag is three-state (1/true/on/yes = on; anything
# else, incl. unset, = off). MEDIA_TASTE_API_URL points at an assumed REST facade for
# the taste/curation store (non-secret base URL; wire shape not verified against a live
# service). If the flag is on but the URL is unset/unreachable, recommendations degrade
# to the stateless path -- personalization is never a hard dependency.
MEDIA_TASTE_MEMORY_ENABLED=
MEDIA_TASTE_API_URL=
# ── Upstream mesh registry (MESH-01) ─────────────────────────────────────────
# Config-driven federation targets, generalizing the single hard-coded upstream
# into a validated registry of many. Both are NON-SECRET structural config,
# read via plain env (never the runtime secret store): a feature flag and a
# JSON array. No credential value is ever authored here — each upstream entry
# references its credential by NAME only (`secret_key`), resolved lazily at
# dial time from the same env-materialized secret store convention every other
# secret in this crate uses.
#
# Master switch. Truthy = 1/true/yes/on (case-insensitive); anything else,
# including unset, leaves the mesh feature dormant (empty registry, never an
# error).
TERMINUS_MESH_ENABLED=
# JSON array of upstream Terminus MCP servers to federate. Each entry:
#   {
#     "name":       stable unique id (e.g. "personal"),
#     "url":        reachable base URL (non-empty),
#     "transport":  "mtls" | "bearer" (case-insensitive),
#     "namespace":  unique prefix, ^[a-z0-9]{2,16}$,
#     "secret_key": NAME of the credential in the runtime secret store
#                   (bearer transports); OMIT for pure-mTLS upstreams —
#                   NEVER an inline token value,
#     "enabled":    bool, default true (false = parsed but not dialed)
#   }
# Loaded/validated at startup; a malformed value while MESH is enabled is a
# clear startup error naming the offending field, not a silent empty registry.
TERMINUS_MESH_UPSTREAMS_JSON=

# ── MESH-04: embedded tailnet listener ──────────────────────────────────────
# Only meaningful when `terminus_primary` is compiled with the `tsnet` Cargo
# feature (off by default -- see Cargo.toml). Two independent gates, both
# must be on for the tailnet listener to actually start: this runtime flag,
# AND the compile-time feature. See src/mesh/tailnet.rs's module doc for the
# full design (binding choice, WhoIs scope boundary).
#
# Runtime master switch for the tsnet listener. Truthy = 1/true/yes/on
# (case-insensitive); anything else, including unset, leaves it off -- the
# plain + mTLS listeners are unaffected either way.
TERMINUS_MESH_TAILNET_ENABLED=

# MagicDNS hostname this node advertises on the tailnet. Required when the
# flag above is on; no auto-generated default (an operator-chosen, stable
# hostname is the point of MagicDNS here).
TERMINUS_TSNET_HOSTNAME=

# Local directory tsnet persists its node state/keys under. Required when the
# flag above is on; created (and write-probed) at startup if missing.
TERMINUS_TSNET_STATE_DIR=

# Tailnet auth key. Like every other credential in this file, this is a
# variable NAME only -- the runtime secret store (<secret-manager>-backed vault)
# materializes the real value into the process environment at deploy time;
# never author a literal key here. Read once at startup and immediately
# wrapped in the redacted `ResolvedSecret` type -- never logged.
TERMINUS_TSNET_AUTHKEY=

# ── MESH-06: unified Principal identity mapping ─────────────────────────────
# Config-driven mapping from an inbound TRANSPORT identity (mTLS client cert
# CN, and/or tailnet WhoIs login/tag) to a single canonical `name` -- the same
# string space `PLANE_PAT_<NAME>` / `GITEA_PAT_<NAME>` / `GITHUB_PAT_<NAME>`
# already use. That canonical name drives BOTH the gateway allowlist/RBAC
# decision (`crate::gateway_framework`) and downstream named-PAT selection.
# NON-SECRET structural config (identity strings, not credential values) --
# read via plain env, same as `TERMINUS_MESH_UPSTREAMS_JSON` above.
#
# Precedence when resolved via `crate::mesh::PrincipalResolver::resolve`
# (see that module's doc for full detail): a present mTLS cert CN is checked
# FIRST and EXCLUSIVELY -- if mapped, it wins outright, even when a tailnet
# identity is also present; if NOT mapped, resolution fails closed (denied)
# rather than falling back to the tailnet identity. Tailnet login/tag is only
# consulted when NO cert is presented. Neither present, or the one presented
# has no mapping entry, => denied. Unlike `TERMINUS_GATEWAY_ALLOWLIST_JSON`,
# malformed JSON here is a HARD startup error, not a silent degrade -- see
# `crate::mesh::principal`'s module doc for why.
#
# JSON object, all three keys optional (absent = empty map for that lookup):
#   {
#     "cert_cn":       { "<mTLS cert Subject CN>": "<canonical name>" },
#     "tailnet_login":  { "<tailnet login>": "<canonical name>" },
#     "tailnet_tag":    { "<tailnet ACL tag, e.g. \"tag:ci\">": "<canonical name>" }
#   }
# Example:
#   {"cert_cn": {"harmony-primary.example.test": "harmony"}, "tailnet_login": {"<email>": "moose"}}
TERMINUS_MESH_PRINCIPAL_MAP_JSON=

# ── TGW-04 / LHEG-07 / MESH-08: gateway per-identity allowlist (RBAC) ───────
# JSON object: `<canonical Principal name> -> <grant>`, where a grant is
# EITHER a plain array (`["tool_a", "tool_b", "*"]`, exact-match plus
# optional bare `"*"` wildcard) OR an allow/deny object
# (`{"allow": [...], "deny": [...]}`, LHEG-07) where `deny` PREFIXES win even
# over an `allow: ["*"]` wildcard. `lumina`/`harmony` are always recognized
# even when absent from this JSON (see `crate::gateway_framework`'s
# `SCAFFOLDED_IDENTITIES` doc); every other identity absent from this map is
# denied every action (default-deny). Malformed JSON degrades to a
# scaffold-only (deny-all except lumina/harmony) policy, logged loudly --
# unlike TERMINUS_MESH_PRINCIPAL_MAP_JSON above, this one must never panic
# the gateway process over a config typo.
#
# MESH-08 (per-upstream, per-tool RBAC over MESH-01/03's namespaced mesh
# tools, `<namespace>__<tool>`): an `allow`/plain-list entry may be:
#   "*"                    -- every tool/route (plain or namespaced)
#   "ct322__*"             -- every tool exported by the mesh upstream
#                              registered under namespace "ct322" (a
#                              namespace-wide wildcard: any entry ending in
#                              "*" matches every action starting with the
#                              text before that "*")
#   "ct322__ledger_add"    -- exactly that one namespaced tool
#   "ledger_add"           -- a plain local tool name (pre-mesh behavior,
#                              unchanged)
# A `deny` PREFIX is checked against the action as given AND, for a
# namespaced action, against its bare (post-`__`) tool name too -- so
# `DEFAULT_SENSITIVE_DENY_PREFIXES` entries like "github_" keep closing off
# a sensitive tool re-exported through ANY mesh upstream namespace, not just
# the local/bare form (e.g. "ct322__github_push_repo" is denied by the
# "github_" deny entry exactly like "github_push_repo" is).
# `tools/list` visibility and `tools/call` enforcement both consult this
# SAME policy for the SAME (possibly namespaced) tool name -- a tool never
# advertised to a caller it could not also call, and vice versa.
#
# Example: grant `ct322-viewer` every ct322 tool except its sensitive
# `vitals_*` ones, and nothing else at all:
#   {"ct322-viewer": {"allow": ["ct322__*"], "deny": ["ct322__vitals_"]}}
TERMINUS_GATEWAY_ALLOWLIST_JSON=
